{
  "name": "ebook-store",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Global English-first (LTR) e-book store with Arabic i18n, Gumroad checkout, and automated marketing assets.",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-books.mjs && node scripts/generate-pdfs.mjs && node scripts/generate-covers.mjs && node scripts/generate-og.mjs && node scripts/generate-promo.mjs && node scripts/generate-seo.mjs && vite build && node scripts/copy-404.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "lint": "tsc --noEmit",
    "covers": "node scripts/generate-covers.mjs",
    "pdfs": "node scripts/generate-pdfs.mjs",
    "seo": "node scripts/generate-seo.mjs",
    "share": "bash share.sh",
    "check-env": "node scripts/setup-env.mjs",
    "deploy": "bash deploy.sh",
    "ig:promote": "node scripts/ig_promote.mjs",
    "gumroad:sync": "node scripts/gumroad_sync.mjs",
    "gumroad:fill": "node scripts/fill-gumroad.mjs",
    "email:stage": "python scripts/_stage_emails.py",
    "email:send": "node scripts/send-sequence.mjs",
    "order:confirm": "node scripts/order_confirm.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.1",
    "sharp": "^0.35.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}