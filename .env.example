# نسخة من هذا الملف إلى .env واملأ قيمك الحقيقية
# مفاتيح جاهزة من بيئتك (تم العثور عليها أثناء العمل):
#   COMPOSIO_API_KEY  ← من ~/.hermes/composio_key  (صالح، استخدمه للنشر عبر Composio)
#   GUMROAD_ACCOUNT   ← ca_ru-ZbwXlFsGQ  (Gumroad ACTIVE — اربط روابط الشراء في books.json)
#   GMAIL_ACCOUNT    ← ca_BmQnzbsU5u3T  (Gmail ACTIVE — تأكيد الطلبات)
#   IG_ACCOUNT       ← ca_d461BvmxN65-  (منتهٍ حاليًا — اربط حساب IG جديد على app.composio.dev)
#
# للدفع على الموقع:
VITE_SNIPCART_API_KEY=YOUR_SNIPCART_PUBLIC_API_KEY
#
# للنشر عبر Composio (انسخ القيمة من ~/.hermes/composio_key):
COMPOSIO_API_KEY=YOUR_COMPOSIO_API_KEY
GUMROAD_ACCOUNT=ca_ru-ZbwXlFsGQ
GMAIL_ACCOUNT=ca_BmQnzbsU5u3T
IG_ACCOUNT=ca_d461BvmxN65-
SELLER_EMAIL=you@example.com
