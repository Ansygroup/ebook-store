# نسخة من هذا الملف إلى .env واملأ قيمتك الحقيقية
# مفتاح Snipcart العام (Public API Key) — من لوحة Snipcart > Account > API Keys
VITE_SNIPCART_API_KEY=YOUR_SNIPCART_PUBLIC_API_KEY

# للإنتاج: حط ملفات PDF/EPUB الخاصة بكل كتاب في public/downloads/
# واربطها عبر data-item-file-guid أعلى معرّف فريد لكل كتاب.
